# Copy this file to `.env` and fill in your own values:  cp .env.example .env
#
# Bring your own Anthropic key. Create one at https://console.anthropic.com/
# (Settings -> API Keys). It bills to YOUR account. You only need it for the
# natural-language chat path -- the enclose_room tool itself can be proven with
# no key at all via:  curl -X POST localhost:5005/api/tools/enclose_room -d '{"roomName":"Yard"}'
ANTHROPIC_API_KEY=

# Cheapest tool-capable Claude model.
LLM__Model=claude-haiku-4-5

# --- Local dev only -------------------------------------------------------
# Leave Auth__Required UNSET (open mode) when running locally with `dotnet run`
# so there is no register/email step -- you land straight in the app.
# For the Docker container path, uncomment the next line to run open too:
# Auth__Required=false
